#!/usr/bin/env bash

set -euo pipefail

BUFFER_NAME="${TMUX_WINDOWS_CLIPBOARD_BUFFER:-__tmux_windows_clipboard__}"
SCRIPT_NAME="${0##*/}"

usage() {
    cat <<'EOF'
Usage:
  tmux-paste-windows-clipboard paste
  tmux-paste-windows-clipboard read
  tmux-paste-windows-clipboard normalize

Modes:
  paste      Read Windows clipboard text, load it into a tmux buffer, and paste
             it with bracketed-paste support when the target application asks.
  read       Print Windows clipboard text with LF newlines to stdout.
  normalize  Read stdin, normalize CRLF/CR to LF, and print to stdout.
EOF
}

display_error() {
    local message="$1"
    if [[ -n "${TMUX:-}" ]] && command -v tmux >/dev/null 2>&1; then
        tmux display-message -- "$message"
    else
        printf '%s\n' "$message" >&2
    fi
}

normalize_to_lf() {
    perl -0pe 's/\r\n/\n/g; s/\r/\n/g'
}

read_windows_clipboard() {
    if command -v win32yank.exe >/dev/null 2>&1; then
        win32yank.exe -o --lf
        return 0
    fi

    if command -v powershell.exe >/dev/null 2>&1; then
        powershell.exe -NoLogo -NoProfile -NonInteractive -Command \
            '[Console]::OutputEncoding = [System.Text.UTF8Encoding]::new($false); $text = Get-Clipboard -Raw; if ($null -ne $text) { [Console]::Out.Write($text) }' \
            | normalize_to_lf
        return 0
    fi

    display_error "$SCRIPT_NAME: need win32yank.exe or powershell.exe"
    return 1
}

paste_into_tmux() {
    if [[ -z "${TMUX:-}" ]]; then
        display_error "$SCRIPT_NAME: not running inside tmux"
        return 1
    fi

    read_windows_clipboard | tmux load-buffer -b "$BUFFER_NAME" -
    tmux paste-buffer -d -p -r -b "$BUFFER_NAME"
}

main() {
    local mode="${1:-paste}"

    case "$mode" in
        paste)
            paste_into_tmux
            ;;
        read)
            read_windows_clipboard
            ;;
        normalize)
            normalize_to_lf
            ;;
        -h|--help|help)
            usage
            ;;
        *)
            display_error "$SCRIPT_NAME: unknown mode: $mode"
            usage >&2
            return 1
            ;;
    esac
}

main "$@"
